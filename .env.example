# Copy this file to .env and fill in real values locally.
# Never commit real keys, app passwords, OAuth tokens, or personal email values.

ANTHROPIC_API_KEY=your_anthropic_api_key_here
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# Optional Gmail IMAP settings.
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_MAILBOX=INBOX
GMAIL_IMAP_LABEL_MAILBOXES=jobs-linkedin-job-alerts
GMAIL_IMAP_SEARCH=ALL
GMAIL_IMAP_MAX_RESULTS=25

# Optional comma-separated recruiter allowlists.
KNOWN_RECRUITER_NAMES=akshay
KNOWN_RECRUITER_EMAILS=

# Optional web search settings for resolving LinkedIn alerts to canonical
# company/ATS job posting URLs. Serper is the primary provider.
SERPER_API_KEY=

# Optional Google-results provider. Use this if you have SerpApi instead of Serper.
SERPAPI_API_KEY=

# Optional fallback provider.
BRAVE_SEARCH_API_KEY=

# Optional legacy fallback. Only used when both values are configured.
# Do not rely on Google Custom Search for new setups.
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
